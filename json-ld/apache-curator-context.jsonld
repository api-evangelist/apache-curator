    },
    "sslPort": {
      "@id": "curator:sslPort",
      "@type": "xsd:integer"
    },
    "stat": {
      "@id": "curator:stat",
      "@type": "@id"
    },
    "state": {
      "@id": "curator:state",
      "@type": "xsd:string"
    },
    "threadCount": {
      "@id": "curator:threadCount",
      "@type": "xsd:integer"
    },
    "version": {
      "@id": "curator:version",
      "@type": "xsd:integer"
    }
